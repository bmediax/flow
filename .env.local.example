# Kinde Auth Configuration
# Get these values from your Kinde dashboard: Settings > Applications > Your app > View details
KINDE_CLIENT_ID=your_kinde_client_id
KINDE_CLIENT_SECRET=your_kinde_client_secret
KINDE_ISSUER_URL=https://your_subdomain.kinde.com
KINDE_SITE_URL=http://localhost:7127
KINDE_POST_LOGOUT_REDIRECT_URL=http://localhost:7127
KINDE_POST_LOGIN_REDIRECT_URL=http://localhost:7127

# Optional: API audience identifier
# KINDE_AUDIENCE=your_api_identifier

# Optional: Cookie domain for subdomain auth (e.g., .mysite.com)
# KINDE_COOKIE_DOMAIN=

# Optional: Enable debug logging
# KINDE_DEBUG_MODE=true

# Kinde Management API (M2M Application)
# Required for syncing user preferences (theme, settings) to Kinde
# Create an M2M application in Kinde dashboard: Settings > Applications > Add Application > Machine to Machine
# Then authorize it for Management API with scopes: read:users, update:users, read:user_properties, update:user_properties
KINDE_MANAGEMENT_CLIENT_ID=your_m2m_client_id
KINDE_MANAGEMENT_CLIENT_SECRET=your_m2m_client_secret

# Optional: Anthropic API key for AI translation (server-side fallback when not set in Settings)
# ANTHROPIC_API_KEY=sk-ant-...
